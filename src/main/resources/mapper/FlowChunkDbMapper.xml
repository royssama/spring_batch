<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.springbatch.flowJobBatchChunk.FlowChunkDbMapper">

    <select id="countSource" resultType="int">
        SELECT COUNT(*) FROM TEST_CHUNK_SOURCE
    </select>

    <select id="countSourceProcessed" resultType="int">
        SELECT COUNT(*) FROM TEST_CHUNK_SOURCE WHERE PROCESSED = 'Y'
    </select>

    <select id="countUnprocessedSource" resultType="int">
        SELECT COUNT(*) FROM TEST_CHUNK_SOURCE WHERE PROCESSED = 'N'
    </select>
</mapper>
